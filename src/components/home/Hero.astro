---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { config } from '../../config';
import { hours } from '../../data/hours';
import CTAButton from '../shared/CTAButton.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const contactHref = lang === 'da' ? '/kontakt' : '/en/contact';
const openLabel = lang === 'da' ? 'Åbent nu' : 'Open now';
const closedLabel = lang === 'da' ? 'Lukket nu' : 'Closed now';
const opensAtLabel = lang === 'da' ? 'Åbner kl.' : 'Opens at';
const closesAtLabel = lang === 'da' ? 'Lukker kl.' : 'Closes at';

// Build JS-day-indexed schedule (0=Sun..6=Sat) from hours data for the client script
const dayMap: Record<string, number> = { Monday: 1, Tuesday: 2, Wednesday: 3, Thursday: 4, Friday: 5, Saturday: 6, Sunday: 0 };
const schedule: Record<number, [string, string]> = {};
for (const h of hours) {
  schedule[dayMap[h.dayOfWeek[0]]] = [h.open, h.close];
}
const scheduleJson = JSON.stringify(schedule);
---

<section class="relative min-h-screen flex items-center justify-center bg-cream overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
    <img src="/images/hero/hero-pattern.svg" alt="" class="w-full h-full object-cover" />
  </div>

  <!-- Decorative floating coffee cup -->
  <div class="absolute right-[8%] top-1/3 w-32 md:w-48 lg:w-56 animate-float opacity-[0.08] hidden md:block" aria-hidden="true">
    <img src="/images/hero/coffee-cup.svg" alt="" class="w-full h-full" />
  </div>

  <!-- Live open/closed indicator -->
  <div
    id="open-indicator"
    class="absolute top-24 md:top-28 left-1/2 -translate-x-1/2 z-20 opacity-0 transition-opacity duration-500"
    data-open-label={openLabel}
    data-closed-label={closedLabel}
    data-opens-at-label={opensAtLabel}
    data-closes-at-label={closesAtLabel}
    data-schedule={scheduleJson}
  >
    <div class="flex items-center gap-3 px-5 py-2.5 rounded-full bg-warm-white/80 backdrop-blur-sm border border-ink/5">
      <!-- Coffee cup icon -->
      <span id="open-icon" class="relative w-5 h-5 flex-shrink-0">
        <!-- Filled cup (open) -->
        <svg id="cup-open" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Steam wisps -->
          <path class="steam-wisp" d="M9 2c0 1.5-1 2.5-1 4s1 2.5 1 4" stroke="#8B1A1A" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
          <path class="steam-wisp" d="M13 3c0 1-0.7 1.8-0.7 2.8s0.7 1.8 0.7 2.8" stroke="#8B1A1A" stroke-width="1.5" stroke-linecap="round" opacity="0.35" style="animation-delay: 0.3s"/>
          <!-- Cup body filled -->
          <rect x="4" y="11" width="12" height="9" rx="2" fill="#8B1A1A"/>
          <!-- Handle -->
          <path d="M16 13h1.5a2 2 0 0 1 0 4H16" stroke="#8B1A1A" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          <!-- Saucer -->
          <path d="M2 21h20" stroke="#8B1A1A" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <!-- Empty cup (closed) -->
        <svg id="cup-closed" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Cup body empty -->
          <rect x="4" y="11" width="12" height="9" rx="2" stroke="#8B1A1A" stroke-width="1.5" fill="none"/>
          <!-- Handle -->
          <path d="M16 13h1.5a2 2 0 0 1 0 4H16" stroke="#8B1A1A" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          <!-- Saucer -->
          <path d="M2 21h20" stroke="#8B1A1A" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      <span id="open-text" class="font-body text-xs font-medium uppercase tracking-[0.15em] text-ink/60"></span>
      <span id="open-detail" class="font-body text-xs font-light text-ink/40 hidden"></span>
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 py-32 md:py-40">
    <h1 class="animate-on-scroll font-display font-black text-[8rem] md:text-[12rem] lg:text-[14rem] text-deep-red leading-[0.85] tracking-wide">
      MORs
    </h1>

    <p class="animate-on-scroll stagger-1 mt-4 font-body text-xs uppercase tracking-[0.3em] text-gold">
      Est. 2026
    </p>

    <p class="animate-on-scroll stagger-2 mt-8 font-display text-2xl md:text-3xl text-ink max-w-lg mx-auto">
      {t(lang, 'hero.tagline')}
    </p>

    <p class="animate-on-scroll stagger-3 mt-4 font-body font-light text-lg text-ink-light max-w-md mx-auto">
      {t(lang, 'hero.subtitle')}
    </p>

    <div class="animate-on-scroll stagger-4 mt-12 flex flex-wrap items-center justify-center gap-6">
      <CTAButton
        href={contactHref}
        variant="primary"
        label={t(lang, 'hero.cta.visit')}
      />
      <CTAButton
        href="#hours"
        variant="outline"
        label={t(lang, 'hero.cta.hours')}
      />
      <CTAButton
        href={`tel:${config.phoneTel}`}
        variant="secondary"
        label={t(lang, 'hero.cta.call')}
      />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <svg class="w-6 h-6 text-ink/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
    </svg>
  </div>
</section>

<script is:inline>
  (function() {
    var indicator = document.getElementById('open-indicator');
    if (!indicator) return;
    var schedule = JSON.parse(indicator.getAttribute('data-schedule') || '{}');

    function toMinutes(hhmm) {
      var parts = hhmm.split(':');
      return parseInt(parts[0]) * 60 + parseInt(parts[1]);
    }

    function formatTime(hhmm) {
      return hhmm.replace(':', '.');
    }

    function update() {
      var cupOpen = document.getElementById('cup-open');
      var cupClosed = document.getElementById('cup-closed');
      var text = document.getElementById('open-text');
      var detail = document.getElementById('open-detail');
      if (!indicator || !cupOpen || !cupClosed || !text || !detail) return;

      var now = new Date();
      var cph = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Copenhagen' }));
      var day = cph.getDay();
      var nowMinutes = cph.getHours() * 60 + cph.getMinutes();
      var hours = schedule[day];

      var openMin = toMinutes(hours[0]);
      var closeMin = toMinutes(hours[1]);
      var isOpen = nowMinutes >= openMin && nowMinutes < closeMin;

      var openLabel = indicator.getAttribute('data-open-label');
      var closedLabel = indicator.getAttribute('data-closed-label');
      var opensAtLabel = indicator.getAttribute('data-opens-at-label');
      var closesAtLabel = indicator.getAttribute('data-closes-at-label');

      if (isOpen) {
        text.textContent = openLabel;
        detail.textContent = closesAtLabel + ' ' + formatTime(hours[1]);
        detail.classList.remove('hidden');
        cupOpen.classList.remove('hidden');
        cupClosed.classList.add('hidden');
      } else {
        text.textContent = closedLabel;
        var nextDay = day;
        var nextHours = hours;
        if (nowMinutes >= closeMin) {
          nextDay = (day + 1) % 7;
          nextHours = schedule[nextDay];
        }
        detail.textContent = opensAtLabel + ' ' + formatTime(nextHours[0]);
        detail.classList.remove('hidden');
        cupOpen.classList.add('hidden');
        cupClosed.classList.remove('hidden');
      }

      indicator.classList.remove('opacity-0');
    }

    update();
    setInterval(update, 60000);
  })();
</script>

<style is:global>
  .steam-wisp {
    animation: steam 2s ease-in-out infinite;
  }
  @keyframes steam {
    0%, 100% { opacity: 0; transform: translateY(0); }
    30% { opacity: 0.5; }
    60% { opacity: 0.3; }
    100% { opacity: 0; transform: translateY(-4px); }
  }
</style>
