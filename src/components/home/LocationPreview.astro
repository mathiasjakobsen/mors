---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { config } from '../../config';
import Container from '../shared/Container.astro';
import SectionHeading from '../shared/SectionHeading.astro';
import OpeningHours from '../shared/OpeningHours.astro';
import CTAButton from '../shared/CTAButton.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const contactHref = lang === 'da' ? '/kontakt' : '/en/contact';
---

<section id="hours" class="bg-cream py-24 md:py-40">
  <Container>
    <SectionHeading title={t(lang, 'home.location.title')} />

    <div data-animate-on-scroll class="max-w-2xl mx-auto text-center mb-16 opacity-0 translate-y-[30px] transition-all duration-[800ms] ease-out">
      <div class="space-y-6">
        <div>
          <h3 class="font-body text-xs uppercase tracking-[0.2em] text-ink/40 mb-3">
            {t(lang, 'contact.address')}
          </h3>
          <p class="font-display text-2xl text-ink">
            {config.address.street}
          </p>
          <p class="font-body font-light text-ink-light mt-1">
            {config.address.zip} {config.address.city}
          </p>
        </div>

        <div class="w-12 h-px bg-deep-red/20 mx-auto"></div>

        <OpeningHours lang={lang} compact={false} />

        <div class="pt-4">
          <CTAButton
            href={contactHref}
            variant="primary"
            label={t(lang, 'hero.cta.visit')}
          />
        </div>
      </div>
    </div>
  </Container>

  <!-- Full-width map -->
  <div data-animate-on-scroll class="w-full h-[400px] md:h-[500px] opacity-0 translate-y-[30px] transition-all duration-[800ms] ease-out">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2222.5!2d10.2107!3d56.1572!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sKlostergade+58%2C+8000+Aarhus+C!5e0!3m2!1sda!2sdk!4v1700000000000"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title={lang === 'da' ? `Kort over ${config.name}, ${config.address.street}` : `Map of ${config.name}, ${config.address.street}`}
    ></iframe>
  </div>
</section>
