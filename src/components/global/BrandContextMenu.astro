---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { brandAssets } from '../../data/brand-assets';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div
  id="brand-context-menu"
  class="fixed z-[80] bg-cream border border-ink/10 rounded-lg shadow-xl py-3 min-w-[220px] opacity-0 pointer-events-none transition-opacity duration-150"
  role="menu"
  aria-label={t(lang, 'brand.title')}
>
  <p class="font-body text-[10px] uppercase tracking-[0.25em] text-ink/40 px-4 pb-2.5 mb-1 border-b border-ink/5 select-none">
    {t(lang, 'brand.title')}
  </p>

  {brandAssets.map((asset) => (
    <a
      href={asset.path}
      download={asset.filename}
      class="flex items-center gap-3 px-4 py-2 font-body text-sm text-ink/70 hover:text-deep-red hover:bg-deep-red/5 transition-colors"
      role="menuitem"
      data-brand-asset-path={asset.path}
      data-brand-asset-filename={asset.filename}
    >
      <svg class="w-4 h-4 shrink-0 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      {asset.label[lang]}
    </a>
  ))}

  <button
    id="brand-download-all"
    type="button"
    class="flex items-center gap-3 w-full text-left px-4 py-2 mt-1 border-t border-ink/5 pt-3 font-body text-sm font-medium text-deep-red hover:text-deep-red-dark transition-colors cursor-pointer"
    role="menuitem"
  >
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
    </svg>
    {t(lang, 'brand.downloadAll')}
  </button>
</div>

<script>
  const logo = document.querySelector('[data-brand-logo]');
  const menu = document.getElementById('brand-context-menu');
  const downloadAllBtn = document.getElementById('brand-download-all');

  function openMenu(x: number, y: number) {
    if (!menu) return;

    menu.style.left = `${x}px`;
    menu.style.top = `${y}px`;
    menu.classList.remove('opacity-0', 'pointer-events-none');
    menu.classList.add('opacity-100');

    // Adjust if menu overflows viewport
    requestAnimationFrame(() => {
      const rect = menu.getBoundingClientRect();
      if (rect.right > window.innerWidth) {
        menu.style.left = `${window.innerWidth - rect.width - 8}px`;
      }
      if (rect.bottom > window.innerHeight) {
        menu.style.top = `${window.innerHeight - rect.height - 8}px`;
      }
    });
  }

  function closeMenu() {
    if (!menu) return;
    menu.classList.add('opacity-0', 'pointer-events-none');
    menu.classList.remove('opacity-100');
  }

  logo?.addEventListener('contextmenu', (e) => {
    e.preventDefault();
    openMenu((e as MouseEvent).clientX, (e as MouseEvent).clientY);
  });

  document.addEventListener('click', (e) => {
    if (menu && !menu.contains(e.target as Node)) {
      closeMenu();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  window.addEventListener('scroll', closeMenu, { passive: true });

  // Close menu after clicking a download link
  menu?.querySelectorAll('a[download]').forEach((link) => {
    link.addEventListener('click', () => {
      setTimeout(closeMenu, 100);
    });
  });

  // Download all as ZIP
  downloadAllBtn?.addEventListener('click', async () => {
    const JSZip = (await import('jszip')).default;
    const zip = new JSZip();
    const assets = menu?.querySelectorAll('[data-brand-asset-path]') ?? [];

    await Promise.all(
      Array.from(assets).map(async (el) => {
        const path = el.getAttribute('data-brand-asset-path');
        const filename = el.getAttribute('data-brand-asset-filename');
        if (!path || !filename) return;
        const response = await fetch(path);
        const blob = await response.blob();
        zip.file(filename, blob);
      })
    );

    const content = await zip.generateAsync({ type: 'blob' });
    const url = URL.createObjectURL(content);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'mors-brand-assets.zip';
    a.click();
    URL.revokeObjectURL(url);
    closeMenu();
  });
</script>
