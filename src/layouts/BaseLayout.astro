---
import type { Lang } from '../i18n/ui';
import { getAlternatePath } from '../i18n/ui';
import { config } from '../config';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath: string;
  ogImage?: string;
  jsonLd?: object;
}

const { title, description, lang, canonicalPath, ogImage, jsonLd } = Astro.props;

const siteUrl = config.siteUrl;
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-default.jpg`;
const ogLocale = lang === 'da' ? 'da_DK' : 'en_US';
const altLang = lang === 'da' ? 'en' : 'da';
const altPath = getAlternatePath(altLang as Lang, canonicalPath);
const altUrl = `${siteUrl}${altPath}`;
const daPath = lang === 'da' ? canonicalPath : altPath;
const enPath = lang === 'en' ? canonicalPath : altPath;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#F5F0E8" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Geo tags -->
    <meta name="geo.region" content={config.geo.region} />
    <meta name="geo.placename" content="Aarhus" />
    <meta name="geo.position" content={`${config.geo.lat};${config.geo.lng}`} />
    <meta name="ICBM" content={`${config.geo.lat}, ${config.geo.lng}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={config.name} />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="da" href={`${siteUrl}${daPath}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${daPath}`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-cream text-ink font-body min-h-screen flex flex-col antialiased">
    <!-- Password gate -->
    <style is:inline>
      #password-gate {
        position: fixed;
        inset: 0;
        z-index: 200;
        background: #ffffff;
        color: #000000;
        overflow: auto;
        font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
        font-size: 13px;
        line-height: 1.45;
        padding: 24px;
      }
      #password-gate h1 {
        font-size: 20px;
        font-weight: 700;
        margin: 0 0 16px 0;
      }
      #password-gate hr {
        border: 0;
        border-top: 1px solid #000;
        margin: 16px 0;
      }
      #password-gate pre {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
        font: inherit;
      }
      #password-gate form { margin: 16px 0; }
      #password-gate label { display: inline-block; margin-right: 8px; }
      #password-gate input[type=password] {
        font: inherit;
        color: #000;
        background: #fff;
        border: 1px solid #000;
        padding: 2px 6px;
        width: 220px;
        border-radius: 0;
        outline: none;
      }
      #password-gate input[type=password]:focus { background: #ffffe0; }
      #password-gate button {
        font: inherit;
        color: #000;
        background: #eee;
        border: 1px solid #000;
        padding: 2px 10px;
        margin-left: 6px;
        border-radius: 0;
        cursor: pointer;
      }
      #password-gate button:hover { background: #ddd; }
      #password-gate .err { color: #b00020; display: none; margin-top: 8px; }
      #password-gate .muted { color: #555; }
      #password-gate footer {
        border-top: 1px solid #000;
        margin-top: 24px;
        padding-top: 8px;
        color: #555;
        font-size: 12px;
      }
    </style>

    <div id="password-gate">
      <h1>401 Unauthorized</h1>
      <pre>Authentication is required to access this resource.

Host:        hosmors.dk
Path:        /
Environment: preview
Build:       2026.04
Session:     anonymous
Status:      401 Unauthorized</pre>

      <hr />

      <form id="password-form" autocomplete="off">
        <label for="password-input">Password:</label>
        <input id="password-input" type="password" autocomplete="off" spellcheck="false" />
        <button type="submit">Submit</button>
        <div id="password-error" class="err">Invalid password. Please try again.</div>
      </form>

      <p class="muted">If you believe you are receiving this message in error, contact the site administrator.</p>

      <footer>
        MORs/1.0 (preview) &mdash; hosmors.dk
      </footer>
    </div>

    <script is:inline>
      (function() {
        var HASH = '8f14e45fceea167a5a36dedd4bea2543';
        var gate = document.getElementById('password-gate');
        if (sessionStorage.getItem('mors-auth') === HASH) {
          gate.remove();
        } else {
          document.body.style.overflow = 'hidden';
          var form = document.getElementById('password-form');
          var input = document.getElementById('password-input');
          var error = document.getElementById('password-error');

          input.focus();
          form.addEventListener('submit', function(e) {
            e.preventDefault();
            var val = input.value;
            if (val === atob('bXVzc2Vibw==')) {
              sessionStorage.setItem('mors-auth', HASH);
              document.body.style.overflow = '';
              gate.remove();
            } else {
              error.style.display = 'block';
              input.value = '';
              input.focus();
            }
          });
        }
      })();
    </script>

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-deep-red focus:text-cream focus:px-4 focus:py-2 focus:rounded-full focus:font-semibold"
    >
      {lang === 'da' ? 'Spring til indhold' : 'Skip to content'}
    </a>
    <slot />

    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
