---
import type { Lang } from '../i18n/ui';
import { getAlternatePath } from '../i18n/ui';
import { config } from '../config';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath: string;
  ogImage?: string;
  jsonLd?: object;
}

const { title, description, lang, canonicalPath, ogImage, jsonLd } = Astro.props;

const siteUrl = config.siteUrl;
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-default.jpg`;
const ogLocale = lang === 'da' ? 'da_DK' : 'en_US';
const altLang = lang === 'da' ? 'en' : 'da';
const altPath = getAlternatePath(altLang as Lang, canonicalPath);
const altUrl = `${siteUrl}${altPath}`;
const daPath = lang === 'da' ? canonicalPath : altPath;
const enPath = lang === 'en' ? canonicalPath : altPath;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#F5F0E8" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Geo tags -->
    <meta name="geo.region" content={config.geo.region} />
    <meta name="geo.placename" content="Aarhus" />
    <meta name="geo.position" content={`${config.geo.lat};${config.geo.lng}`} />
    <meta name="ICBM" content={`${config.geo.lat}, ${config.geo.lng}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={config.name} />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="da" href={`${siteUrl}${daPath}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${daPath}`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-cream text-ink font-body min-h-screen flex flex-col antialiased">
    <!-- Coming soon gate -->
    <style is:inline>
      #coming-soon-gate {
        position: fixed;
        inset: 0;
        z-index: 200;
        background: #f6f0e7;
        color: #1a1a1a;
        overflow: auto;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
        font-family: 'DM Sans', system-ui, sans-serif;
      }
      #coming-soon-gate .inner {
        max-width: 560px;
        width: 100%;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 56px;
      }
      #coming-soon-gate .wordmark {
        width: min(360px, 70vw);
        height: auto;
        display: block;
      }
      #coming-soon-gate .opening {
        font-family: 'DM Sans', system-ui, sans-serif;
        font-weight: 500;
        font-size: 13px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #8B1A1A;
        margin: 0;
        line-height: 1.4;
      }
      #coming-soon-gate .address {
        font-weight: 300;
        font-size: 15px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #1a1a1a;
        line-height: 2;
        margin: 0;
      }
      #coming-soon-gate .rule {
        width: 40px;
        height: 1px;
        background: #8B1A1A;
        opacity: 0.4;
        margin: 0 auto;
      }
      #coming-soon-gate .socials {
        display: flex;
        gap: 28px;
        align-items: center;
        justify-content: center;
      }
      #coming-soon-gate .socials a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        color: #8B1A1A;
        text-decoration: none;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), color 0.3s ease, background-color 0.3s ease;
      }
      #coming-soon-gate .socials a:hover {
        transform: translateY(-3px);
        color: #f6f0e7;
        background-color: #8B1A1A;
      }
      #coming-soon-gate .socials svg {
        width: 22px;
        height: 22px;
      }
      #coming-soon-gate .stagger-item {
        opacity: 0;
        transform: translateY(12px);
        animation: gateRise 0.9s ease-out forwards;
      }
      #coming-soon-gate .stagger-item:nth-child(1) { animation-delay: 0.15s; }
      #coming-soon-gate .stagger-item:nth-child(2) { animation-delay: 0.35s; }
      #coming-soon-gate .stagger-item:nth-child(3) { animation-delay: 0.55s; }
      #coming-soon-gate .stagger-item:nth-child(4) { animation-delay: 0.75s; }
      #coming-soon-gate.dismiss {
        animation: gateFadeOut 0.8s ease-in forwards;
      }
      @keyframes gateFadeOut {
        from { opacity: 1; }
        to { opacity: 0; visibility: hidden; }
      }
      @keyframes gateRise {
        to { opacity: 1; transform: translateY(0); }
      }
      @media (prefers-reduced-motion: reduce) {
        #coming-soon-gate,
        #coming-soon-gate .stagger-item,
        #coming-soon-gate.dismiss {
          animation: none;
        }
        #coming-soon-gate .stagger-item {
          opacity: 1;
          transform: none;
        }
      }
    </style>

    <div id="coming-soon-gate" role="dialog" aria-label="morˢ — Åbner juni 2026">
      <div class="inner">
        <img
          class="wordmark stagger-item"
          src="/brand/mors-wordmark-v2.png"
          alt="morˢ"
          width="320"
          height="64"
        />
        <p class="opening stagger-item">Åbner juni 2026</p>
        <address class="address stagger-item" style="font-style: normal;">
          Klostergade 58<br />
          8000 Aarhus C
        </address>
        <div class="socials stagger-item">
          <a href="https://www.facebook.com/www.mors.coffee" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13.5 21.95v-8.3h2.79l.42-3.24H13.5V8.34c0-.94.26-1.58 1.6-1.58h1.71V3.86c-.3-.04-1.32-.13-2.5-.13-2.48 0-4.18 1.51-4.18 4.29v2.39H7.33v3.24h2.8v8.3h3.37z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/_mors.coffee" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.3" cy="6.7" r="0.6" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        var gate = document.getElementById('coming-soon-gate');
        if (!gate) return;
        var STORAGE_KEY = 'mors-gate-dismissed';

        if (sessionStorage.getItem(STORAGE_KEY) === '1') {
          gate.remove();
          return;
        }

        document.body.style.overflow = 'hidden';

        window.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            sessionStorage.setItem(STORAGE_KEY, '1');
            gate.classList.add('dismiss');
            setTimeout(function() {
              document.body.style.overflow = '';
              gate.remove();
            }, 800);
          }
        });
      })();
    </script>

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-deep-red focus:text-cream focus:px-4 focus:py-2 focus:rounded-full focus:font-semibold"
    >
      {lang === 'da' ? 'Spring til indhold' : 'Skip to content'}
    </a>
    <slot />

    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
