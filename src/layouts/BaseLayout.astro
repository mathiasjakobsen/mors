---
import type { Lang } from '../i18n/ui';
import { getAlternatePath } from '../i18n/ui';
import { config } from '../config';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath: string;
  ogImage?: string;
  jsonLd?: object;
}

const { title, description, lang, canonicalPath, ogImage, jsonLd } = Astro.props;

const siteUrl = config.siteUrl;
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-default.jpg`;
const ogLocale = lang === 'da' ? 'da_DK' : 'en_US';
const altLang = lang === 'da' ? 'en' : 'da';
const altPath = getAlternatePath(altLang as Lang, canonicalPath);
const altUrl = `${siteUrl}${altPath}`;
const daPath = lang === 'da' ? canonicalPath : altPath;
const enPath = lang === 'en' ? canonicalPath : altPath;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#F5F0E8" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Geo tags -->
    <meta name="geo.region" content={config.geo.region} />
    <meta name="geo.placename" content="Aarhus" />
    <meta name="geo.position" content={`${config.geo.lat};${config.geo.lng}`} />
    <meta name="ICBM" content={`${config.geo.lat}, ${config.geo.lng}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={config.name} />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="da" href={`${siteUrl}${daPath}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${daPath}`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-cream text-ink font-body min-h-screen flex flex-col antialiased">
    <div
      id="coming-soon-gate"
      role="dialog"
      aria-label="morˢ — Åbner juni 2026"
      class="fixed inset-0 z-[200] overflow-auto flex items-center justify-center px-6 py-12 bg-[#f6f0e7] text-ink font-body transition-opacity duration-[800ms]"
    >
      <div class="absolute top-5 sm:top-8 inset-x-0 flex justify-center px-4 sm:px-6 pointer-events-none">
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Åbningsweekend 13. og 14. juni, kl. 08:30 til 16:00 — kom og vær med"
          class="group pointer-events-auto inline-flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4 max-w-[560px] px-5 sm:px-[22px] py-3 sm:py-3 rounded-[28px] sm:rounded-full bg-[#fffaf2] border border-[#8B1A1A]/20 text-[12.5px] sm:text-[13.5px] text-ink leading-snug no-underline opacity-0 animate-[fadeUp_0.9s_ease-out_0.15s_both] transition-[background-color,border-color,transform] duration-300 hover:bg-[#fdf2e0] hover:border-[#8B1A1A]/40 hover:-translate-y-px"
        >
          <span class="inline-flex flex-wrap items-center justify-center gap-x-2 text-center opacity-[0.85] sm:flex-nowrap">
            <span aria-hidden="true" class="text-[15px] leading-none">✨</span>
            <span>Åbningsweekend · 13.–14. juni · 08:30–16:00</span>
            <span aria-hidden="true" class="text-[15px] leading-none">🥐 ☕</span>
          </span>
          <span class="inline-flex items-center gap-2 text-[11px] font-medium uppercase tracking-[0.2em] text-[#8B1A1A] whitespace-nowrap transition-[gap] duration-300 group-hover:gap-3">
            Kom og vær med
            <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="w-[11px] h-[11px]">
              <line x1="2" y1="7" x2="12" y2="7" />
              <polyline points="8,3 12,7 8,11" />
            </svg>
          </span>
        </a>
      </div>

      <div class="w-full max-w-[560px] text-center flex flex-col items-center gap-14">
        <img
          src="/brand/mors-wordmark.png"
          alt="morˢ"
          width="320"
          height="64"
          class="block h-auto w-[min(70vw,360px)] opacity-0 animate-[fadeUp_0.9s_ease-out_0.35s_both]"
        />
        <p class="m-0 text-[13px] font-medium uppercase tracking-[0.22em] leading-tight text-[#8B1A1A] opacity-0 animate-[fadeUp_0.9s_ease-out_0.55s_both]">
          Åbner juni 2026
        </p>
        <address class="m-0 not-italic text-[15px] font-light uppercase tracking-[0.08em] leading-loose text-ink opacity-0 animate-[fadeUp_0.9s_ease-out_0.75s_both]">
          Klostergade 58<br />
          8000 Aarhus C
        </address>
        <div class="flex items-center justify-center gap-7 opacity-0 animate-[fadeUp_0.9s_ease-out_0.95s_both]">
          <a
            href="https://www.facebook.com/www.mors.coffee"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex items-center justify-center w-11 h-11 rounded-full text-[#8B1A1A] no-underline transition-[transform,color,background-color] duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:-translate-y-[3px] hover:text-[#f6f0e7] hover:bg-[#8B1A1A]"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="w-[22px] h-[22px]">
              <path d="M13.5 21.95v-8.3h2.79l.42-3.24H13.5V8.34c0-.94.26-1.58 1.6-1.58h1.71V3.86c-.3-.04-1.32-.13-2.5-.13-2.48 0-4.18 1.51-4.18 4.29v2.39H7.33v3.24h2.8v8.3h3.37z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/_mors.coffee"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="inline-flex items-center justify-center w-11 h-11 rounded-full text-[#8B1A1A] no-underline transition-[transform,color,background-color] duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:-translate-y-[3px] hover:text-[#f6f0e7] hover:bg-[#8B1A1A]"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="w-[22px] h-[22px]">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.3" cy="6.7" r="0.6" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        var gate = document.getElementById('coming-soon-gate');
        if (!gate) return;
        var STORAGE_KEY = 'mors-gate-dismissed';

        if (sessionStorage.getItem(STORAGE_KEY) === '1') {
          gate.remove();
          return;
        }

        document.body.style.overflow = 'hidden';

        window.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            sessionStorage.setItem(STORAGE_KEY, '1');
            gate.classList.add('opacity-0');
            setTimeout(function() {
              document.body.style.overflow = '';
              gate.remove();
            }, 800);
          }
        });
      })();
    </script>

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-deep-red focus:text-cream focus:px-4 focus:py-2 focus:rounded-full focus:font-semibold"
    >
      {lang === 'da' ? 'Spring til indhold' : 'Skip to content'}
    </a>
    <slot />

    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target;
            el.classList.remove('opacity-0', 'translate-y-[30px]');
            el.classList.add('opacity-100', 'translate-y-0');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('[data-animate-on-scroll]').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
