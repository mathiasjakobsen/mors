---
import PageLayout from '../../layouts/PageLayout.astro';
import { t } from '../../i18n/ui';
import { getMenuCategories } from '../../lib/api';
import { menuSchema } from '../../utils/jsonld';
import Container from '../../components/shared/Container.astro';
import SectionHeading from '../../components/shared/SectionHeading.astro';

const lang = 'en';
const menuCategories = await getMenuCategories();

const tagLabels: Record<string, string> = {
  oeko: 'Organic',
  vegan: 'Vegan',
  glutenfri: 'Gluten-free',
  seasonal: 'Seasonal',
};
---

<PageLayout
  title={t(lang, 'seo.menu.title')}
  description={t(lang, 'seo.menu.description')}
  lang={lang}
  canonicalPath="/en/menu"
  jsonLd={menuSchema(menuCategories, lang)}
>
  <section class="bg-warm-white py-24 md:py-40">
    <Container>
      <SectionHeading title={t(lang, 'menu.title')} subtitle={t(lang, 'menu.description')} />

      <div class="max-w-2xl mx-auto space-y-20">
        {menuCategories.map((category) => (
          <div class="animate-on-scroll">
            <h2 class="font-display font-bold text-3xl text-deep-red mb-8 text-center">
              {category.name[lang]}
            </h2>

            <div class="space-y-5">
              {category.items.filter((item) => !item.image).map((item) => (
                <div>
                  <div class="flex items-baseline gap-3">
                    <span class="font-body font-normal text-ink">
                      {item.name[lang]}
                    </span>
                    {item.tags && item.tags.length > 0 && (
                      <span class="flex gap-1.5">
                        {item.tags.map((tag) => (
                          <span class="text-[10px] uppercase tracking-[0.15em] font-body text-sage font-normal">
                            {tagLabels[tag]}
                          </span>
                        ))}
                      </span>
                    )}
                    <span class="flex-1 border-b border-dotted border-ink/10 translate-y-[-4px]" />
                    <span class="font-body font-normal text-ink whitespace-nowrap">
                      {item.price} DKK
                    </span>
                  </div>
                  {item.description && (
                    <p class="font-body font-light text-sm text-ink-light mt-1">
                      {item.description[lang]}
                    </p>
                  )}
                </div>
              ))}
            </div>

            {category.items.some((item) => item.image) && (
              <div class="grid grid-cols-2 gap-6 mt-10">
                {category.items.filter((item) => item.image).map((item) => (
                  <div class="group text-center">
                    <div class="aspect-[3/4] overflow-hidden rounded-lg bg-white border border-ink/5 mb-4 flex items-center justify-center p-5">
                      <img
                        src={item.image}
                        alt={item.name[lang]}
                        loading="lazy"
                        class="max-h-full w-auto object-contain transition-transform duration-[600ms] ease-out group-hover:scale-105"
                      />
                    </div>
                    <div class="flex items-baseline justify-center gap-2">
                      <span class="font-body font-normal text-ink">{item.name[lang]}</span>
                      <span class="font-body font-normal text-ink-light whitespace-nowrap">{item.price} DKK</span>
                    </div>
                    {item.tags && item.tags.length > 0 && (
                      <div class="flex justify-center gap-1.5 mt-1">
                        {item.tags.map((tag) => (
                          <span class="text-[10px] uppercase tracking-[0.15em] font-body text-sage font-normal">
                            {tagLabels[tag]}
                          </span>
                        ))}
                      </div>
                    )}
                    {item.description && (
                      <p class="font-body font-light text-sm text-ink-light mt-2 max-w-[28ch] mx-auto">
                        {item.description[lang]}
                      </p>
                    )}
                  </div>
                ))}
              </div>
            )}

            <div class="mt-12 w-16 h-px bg-deep-red/10 mx-auto"></div>
          </div>
        ))}
      </div>
    </Container>
  </section>
</PageLayout>
