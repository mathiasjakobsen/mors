---
import PageLayout from '../layouts/PageLayout.astro';
import { t } from '../i18n/ui';
import Container from '../components/shared/Container.astro';

const lang = 'da';
---

<PageLayout
  title={t(lang, 'seo.about.title')}
  description={t(lang, 'seo.about.description')}
  lang={lang}
  canonicalPath="/om"
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] md:min-h-[75vh] overflow-hidden">
    <img
      src="/images/mors-founders.jpg"
      alt="Mathias og Johanne, grundlæggerne af morˢ"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-deep-red/30 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/30"></div>
    <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-b from-transparent to-warm-white/50"></div>
    <Container>
      <div class="relative min-h-[60vh] md:min-h-[75vh] flex items-end pb-16 md:pb-24">
        <div data-animate-on-scroll class="opacity-0 translate-y-[30px] transition-all duration-[800ms] ease-out">
          <h1 class="font-mors font-bold text-5xl md:text-7xl text-warm-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.35)]">
            Om morˢ
          </h1>
        </div>
      </div>
    </Container>
  </section>

  <!-- Content — placeholder, awaiting the real story -->
  <section class="bg-warm-white py-24 md:py-40">
    <Container>
      <div data-animate-on-scroll class="max-w-2xl mx-auto text-center opacity-0 translate-y-[30px] transition-all duration-[800ms] ease-out">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-gold mb-6">Under opbygning ☕</p>
        <h2 class="font-display font-bold text-3xl md:text-5xl text-deep-red mb-8">
          Her skulle der stå noget klogt om os
        </h2>
        <div class="font-body font-light text-ink-light leading-loose space-y-6 text-lg">
          <p>
            Men så blev kaffen vigtigere. Vores historie er stadig ved at trække &mdash; den er
            klar, så snart vi har drukket espresso nok til at skrive den ned.
          </p>
          <p>
            Indtil da: kig forbi på Klostergade 58, så fortæller vi den hellere end gerne over en
            voldsomt god islatte.
          </p>
        </div>
        <p class="mt-12 font-display italic text-2xl text-deep-red/70">
          Knus, morˢ &mdash; et sted, der stadig leder efter de helt rigtige ord
        </p>
      </div>
    </Container>
  </section>
</PageLayout>
