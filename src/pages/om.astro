---
import PageLayout from '../layouts/PageLayout.astro';
import { t } from '../i18n/ui';
import Container from '../components/shared/Container.astro';

const lang = 'da';

const gallery = [
  { src: '/images/mors-bindingsvaerk.jpg', title: 'Fredet bindingsværk fra 1600-tallet' },
  { src: '/images/mors-bag-baren.jpg',     title: 'Bag baren' },
  { src: '/images/mors-morgenmad.jpg',     title: 'Morgenmad i solen' },
  { src: '/images/mors-doer.jpg',          title: 'Døren står åben' },
  { src: '/images/mors-baren.jpg',         title: 'Mens vi brygger' },
  { src: '/images/mors-cafe.jpg',          title: 'Plads til en snak' },
];
---

<PageLayout
  title={t(lang, 'seo.about.title')}
  description={t(lang, 'seo.about.description')}
  lang={lang}
  canonicalPath="/om"
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] md:min-h-[75vh] overflow-hidden">
    <img
      src="/images/mors-founders.jpg"
      alt="Mathias og Johanne, grundlæggerne af morˢ"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-deep-red/30 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/30"></div>
    <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-b from-transparent to-warm-white/50"></div>
    <Container>
      <div class="relative min-h-[60vh] md:min-h-[75vh] flex items-end pb-16 md:pb-24">
        <div data-animate-on-scroll class="opacity-0 translate-y-[30px] transition-all duration-[800ms] ease-out">
          <h1 class="font-mors font-bold text-5xl md:text-7xl text-warm-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.35)]">
            Om morˢ
          </h1>
        </div>
      </div>
    </Container>
  </section>

  <!-- Gallery -->
  <section class="bg-warm-white py-24 md:py-40">
    <Container>
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 md:gap-8">
        {gallery.map((item) => (
          <figure data-animate-on-scroll class="mb-6 md:mb-8 break-inside-avoid opacity-0 translate-y-[30px] transition-all duration-[800ms] ease-out">
            <div class="overflow-hidden rounded-mors bg-cream">
              <img
                src={item.src}
                alt={item.title}
                loading="lazy"
                decoding="async"
                class="w-full h-auto object-cover transition-transform duration-[1200ms] ease-out hover:scale-[1.03]"
              />
            </div>
            <figcaption class="mt-3 font-body text-xs uppercase tracking-[0.2em] text-ink/50">
              {item.title}
            </figcaption>
          </figure>
        ))}
      </div>
    </Container>
  </section>
</PageLayout>
